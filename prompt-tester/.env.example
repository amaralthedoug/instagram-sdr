# Claude API — required for real prompt testing and resumo generation
ANTHROPIC_API_KEY=sk-ant-...

# Backend (testn8nmetaapi) — required for the ManyChat webhook to send leads
BACKEND_URL=https://your-backend-url.com
BACKEND_API_KEY=your-shared-secret

# ManyChat webhook authentication — optional but recommended
# Set this in ManyChat's External Request header: X-Webhook-Secret
WEBHOOK_SECRET=your-webhook-secret
